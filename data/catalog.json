    {
      "id": "motion-fade-up",
      "name": "Animação — Fade up",
      "nameEn": "Motion — Fade up",
      "kind": "animation",
      "preview": {
        "type": "code",
        "language": "css",
        "code": "@keyframes give-fade-up {\n  from {\n    opacity: 0;\n    transform: translateY(12px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.give-fade-up {\n  animation: give-fade-up 0.45s cubic-bezier(0.4, 0, 0.2, 1) both;\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .give-fade-up {\n    animation: none;\n  }\n}"
      },
